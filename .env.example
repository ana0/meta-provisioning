ENV=development
PROJECT=meta-server

# Redis
REDIS_URL=redis://:redis@redis:6379
REDIS_PASSWORD=redis

# Postgres database
POSTGRES_PASSWORD=postgres
POSTGRES_USER=postgres
POSTGRES_DB=postgres

# Tracking
TRACKING_PASSWORD=
TRACKING_ORIGIN=
TRACKING_OURA_TOKEN=

# Meta-server
BASE_PATH=http://localhost:8000
PORT=8088

# Ethereum / Polygon RPC endpoints
POLYGON_NODE_WS=wss://your-polygon-ws-endpoint
POLYGON_NODE=https://your-polygon-http-endpoint
ETHEREUM_NODE_WS=wss://mainnet.infura.io/ws/v3/YOUR_INFURA_PROJECT_ID
ETHEREUM_NODE=https://mainnet.infura.io/v3/YOUR_INFURA_PROJECT_ID

# Signing key used by the worker to write to contracts (hex, no 0x prefix)
GRAVEDIGGER_PRIV_KEY=

# OFF
OFF_CONTROLLER_ADDRESS=
OFF_CONTROLLER=
OFF_CONTRACT=

# Lifeforms
LIFEFORMS_CONTRACT=

# Wildcards
WILDCARDS_CONTROLLER=
WILDCARDS_CONTROLLER_ADDRESS=
WILDCARDS_CONTRACT=

# Mirror piece
MIRROR_CONTROLLER=
MIRROR_CONTRACT=

# Memoryforms
MEMORYFORMS_CONTROLLER=
MEMORYFORMS_CONTRACT=

# Charon
CHARON_CONTROLLER=
CHARON_CONTRACT=
